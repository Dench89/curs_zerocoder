# ===================================================
# Python
# ===================================================

venv/                 # Виртуальное окружение Python.
__pycache__/          # Кэш Python (скомпилированные файлы).
*.pyc                 # Все скомпилированные файлы Python.
*.pyo                 # Оптимизированные файлы Python.
*.pyd                 # Расширения Python для Windows.

# ===================================================
# Visual Studio Code
# ===================================================

.vscode/              # Личные настройки VS Code.

# ===================================================
# Кэш
# ===================================================

.pytest_cache/        # Кэш тестов pytest.
.mypy_cache/          # Кэш проверки типов mypy.
.ruff_cache/          # Кэш линтера Ruff.

# ===================================================
# Логи
# ===================================================

*.log                 # Все файлы журналов.

# ===================================================
# Переменные окружения
# ===================================================

.env                  # Основной файл с секретами (пароли, токены).
.env.*                # Дополнительные файлы окружения (.env.local и др.).

# ===================================================
# Локальные настройки JSON
# ===================================================

*.local.json          # Локальные JSON-файлы.
config.local.json     # Локальная конфигурация.
settings.local.json   # Локальные настройки программы.

# ===================================================
# Базы данных SQLite
# ===================================================

*.db                  # Локальные базы данных SQLite.
*.sqlite3             # Файлы SQLite.

# ===================================================
# Архивы
# ===================================================

*.zip                 # ZIP-архивы.
*.rar                 # RAR-архивы.
*.7z                  # 7Z-архивы.

# ===================================================
# Системные файлы Windows
# ===================================================

Thumbs.db             # Кэш миниатюр Windows.
Desktop.ini           # Настройки папок Windows.

# ===================================================
# Системные файлы macOS
# ===================================================

.DS_Store             # Служебный файл macOS.

# ===================================================
# Временные файлы редакторов
# ===================================================

*.tmp                 # Временные файлы.
*.bak                 # Резервные копии файлов.
*.swp                 # Временные файлы Vim.
*.swo                 # Дополнительные временные файлы Vim.